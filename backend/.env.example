# ═══════════════════════════════════════════
#  TaskFlow Backend — Environment Variables
# ═══════════════════════════════════════════

APP_NAME=TaskFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-backend.up.railway.app
FRONTEND_URL=https://seu-frontend.up.railway.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─── Database (SQLite no volume persistente) ───
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# ─── Sessions & Cache ────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Pusher (Real-time) ──────────────────
BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=sa1

# ─── Mail ─────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@taskflow.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── API Docs ────────────────────────────
API_DOCS_ENABLED=false
